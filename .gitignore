# Godot 4 — rebuilt on import, never commit
.godot/
.import/

# Checkpoint screenshots (out/checkpoints/) are documentation artifacts, not
# game assets — the .import sidecar Godot generates for them is regenerated
# identically on any checkout and isn't worth committing.
out/checkpoints/**/*.import

# Export artifacts
export_presets.cfg
*.tmp

# Cloned GUT working dir if you clone to repo root by mistake
/tmp/gut/

# Local build/workflow notes — not published
/CLAUDE.md

# Regenerated every run — checkpoint artifacts under out/checkpoints/ ARE
# committed (docs/09); this rolling log is not.
/out/combat.log
